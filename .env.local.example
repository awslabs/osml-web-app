# Environment variables for local development
# Copy this file to .env.local and update the values for your deployment:
#   cp .env.local.example .env.local

# Tile Server URL - provides map tile imagery
NEXT_PUBLIC_TILE_SERVER_URL=https://your-tile-server.example.com

# STAC Catalog URL - provides access to geospatial data catalog
NEXT_PUBLIC_STAC_CATALOG_URL=https://your-stac-catalog.example.com

# Utility API URL - provides web app utility functions (S3, Bedrock, quotas)
NEXT_PUBLIC_UTILITY_API_URL=https://your-utility-api.execute-api.us-west-2.amazonaws.com/prod

# Model Runner API URL - provides ML model execution services
NEXT_PUBLIC_MODEL_RUNNER_API_URL=https://your-model-runner-api.execute-api.us-west-2.amazonaws.com/prod

# Geo Agents MCP URL - provides geospatial agent services
NEXT_PUBLIC_GEO_AGENTS_MCP_URL=https://your-geo-agent-mcp.example.com

# Kinesis Stream Name - Model Runner detection output stream
# Auto-derived from account ID at deploy time (mr-stream-sink-{account_id}).
# Only set this to override the default convention.
NEXT_PUBLIC_KINESIS_STREAM_NAME=

# OIDC Authority - authentication server endpoint
NEXT_PUBLIC_OIDC_AUTHORITY=https://your-keycloak.example.com/realms/osml

# NextAuth Configuration
# NextAuth URL - the base URL of your application (use localhost for local dev)
NEXTAUTH_URL=http://localhost:3000

# NextAuth Client ID - OAuth client identifier
NEXTAUTH_CLIENT_ID=osml-client

# NextAuth Secret - used to encrypt JWT tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=replace-with-generated-secret

# Note: For local development, you may need to:
# 1. Replace the URLs above with your deployed service endpoints
# 2. Generate a proper NEXTAUTH_SECRET using: openssl rand -base64 32
