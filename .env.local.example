# Environment variables for local development
# Copy this file to .env.local and update the values for your deployment:
#   cp .env.local.example .env.local
#
# These values are read at server boot (or by `next dev` for local development)
# and injected into the SSR'd HTML as window.__OSML_CONFIG__ by the root
# layout. Client-side code reads them via `siteConfig`. Build artifacts no
# longer bake these in, so the same build can be deployed to any environment.

# Tile Server URL - provides map tile imagery
TILE_SERVER_URL=https://your-tile-server.example.com

# STAC Catalog URL - provides access to geospatial data catalog
STAC_CATALOG_URL=https://your-stac-catalog.example.com

# Utility API URL - provides web app utility functions (S3, Bedrock, quotas)
UTILITY_API_URL=https://your-utility-api.execute-api.us-west-2.amazonaws.com/prod

# Model Runner API URL - provides ML model execution services
MODEL_RUNNER_API_URL=https://your-model-runner-api.execute-api.us-west-2.amazonaws.com/prod

# Geo Agents MCP URL - provides geospatial agent services
GEO_AGENTS_MCP_URL=https://your-geo-agent-mcp.example.com

# STAC Loader MCP URL (optional) - MCP endpoint for the STAC loader service
STAC_LOADER_MCP_URL=

# Local MCP server URL (used for development against a self-hosted MCP server)
# Default: http://localhost:3001
MCP_SERVER_URL=

# Detection bridge S3 bucket - target bucket for detection bridge results
DETECTION_BRIDGE_BUCKET=

# Kinesis Stream Name - Model Runner detection output stream
# Auto-derived from account ID at deploy time (mr-stream-sink-{account_id}).
# Only set this to override the default convention.
KINESIS_STREAM_NAME=

# Maximum tool calls per chat turn before the agent stops automatically.
# Default: 20
TOOL_CALL_LIMIT=

# OIDC Authority - authentication server endpoint
# Server-side only (used by NextAuth); never exposed to the client.
OIDC_AUTHORITY=https://your-keycloak.example.com/realms/osml

# NextAuth Configuration
# NextAuth URL - the base URL of your application (use localhost for local dev)
NEXTAUTH_URL=http://localhost:3000

# NextAuth Client ID - OAuth client identifier
NEXTAUTH_CLIENT_ID=osml-client

# NextAuth Secret - used to encrypt JWT tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=replace-with-generated-secret

# Note: For local development, you may need to:
# 1. Replace the URLs above with your deployed service endpoints
# 2. Generate a proper NEXTAUTH_SECRET using: openssl rand -base64 32
