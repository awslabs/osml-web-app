# See https://help.github.com/articles/ignoring-files/ for more image ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# cdk
/cdk/node_modules/
/cdk/cdk.out/
/cdk/cdk.context.json
/cdk/bin/deployment/deployment.json
/cdk/lib/constructs/layer/*
!/cdk/lib/constructs/layer/.gitkeep
/cdk/cdk-nag-suppressions-report.txt
/cdk/.cdk-nag-suppressions-temp.json

# testing
/coverage

# cypress artifacts
/cypress/videos/
/cypress/screenshots/
/cypress/downloads/

# next.js
/.next/
/out/

# production
/build
/public/cesium
/public/.ignored_cesium
/build.zip

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env.development
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]
*$py.class
.tox/
.hypothesis/
.coverage
htmlcov/
.mypy_cache/
.pytest_cache/

# ASH (Automated Security Helper) local run outputs
.ash/ash_output/
.ash/*_out.txt

# cdk build output
cdk/dist/
cdk/lib/**/*.js
cdk/lib/**/*.d.ts
cdk/bin/**/*.js
cdk/bin/**/*.d.ts

# IDE
.idea/
.vscode/
